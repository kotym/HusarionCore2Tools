{
    "name":  "husarion-core2-tools",
    "displayName":  "Husarion CORE2 Development Tools",
    "description":  "Embedded development tools for Husarion CORE2 (STM32F4): project creation, CMake build/flash, IntelliSense configuration, and serial debugging.",
    "version":  "1.0.2",
    "publisher":  "local",
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/kotym/HusarionCore2Tools.git"
                   },
    "license":  "MIT",
    "engines":  {
                    "vscode":  "^1.84.0"
                },
    "categories":  [
                       "Other",
                       "Programming Languages",
                       "Debuggers"
                   ],
    "activationEvents":  [
                             "onStartupFinished"
                         ],
    "main":  "./extension.js",
    "contributes":  {
                        "commands":  [
                                         {
                                             "command":  "husarionCore2.createProject",
                                             "title":  "Husarion: Create CORE2 Project"
                                         },
                                         {
                                             "command":  "husarionCore2.buildProject",
                                             "title":  "Husarion: Build Project (No Flash)"
                                         },
                                         {
                                             "command":  "husarionCore2.rebuildProject",
                                             "title":  "Husarion: Rebuild Project (Clean All Build Dirs)"
                                         },
                                         {
                                             "command":  "husarionCore2.flashProject",
                                             "title":  "Husarion: Build + Flash Project to CORE2"
                                         },
                                         {
                                             "command":  "husarionCore2.flashOnly",
                                             "title":  "Husarion: Flash Latest HEX (No Build)"
                                         },
                                         {
                                             "command":  "husarionCore2.openConsole",
                                             "title":  "Husarion: Open CORE2 Serial Console"
                                         },
                                         {
                                             "command":  "husarionCore2.installDependencies",
                                             "title":  "Husarion: Install Required Toolchain and Components"
                                         },
                                         {
                                             "command":  "husarionCore2.checkForUpdates",
                                             "title":  "Husarion: Check for Updates"
                                         }
                                     ],
                        "configuration":  {
                                              "title":  "Husarion CORE2 Tools",
                                              "properties":  {
                                                                 "husarionCore2.hframeworkPath":  {
                                                                                                      "type":  "string",
                                                                                                      "default":  "",
                                                                                                      "description":  "Optional absolute path to hFramework root directory. Leave empty for auto-detection from project CMakeLists, env HFRAMEWORK_PATH, or sibling folders."
                                                                                                  },
                                                                 "husarionCore2.templatePath":  {
                                                                                                    "type":  "string",
                                                                                                    "default":  "",
                                                                                                    "description":  "Optional override path for project template directory. Leave empty to use \u003chframeworkPath\u003e/project_template."
                                                                                                },
                                                                 "husarionCore2.flasherPath":  {
                                                                                                   "type":  "string",
                                                                                                   "default":  "",
                                                                                                   "description":  "Optional override path to core2-flasher executable. Leave empty to use \u003chframeworkPath\u003e/tools/win/core2-flasher.exe."
                                                                                               },
                                                                 "husarionCore2.boardType":  {
                                                                                                 "type":  "string",
                                                                                                 "default":  "core2",
                                                                                                 "description":  "BOARD_TYPE used in CMake configure command."
                                                                                             },
                                                                 "husarionCore2.hSensorsPath":  {
                                                                                                    "type":  "string",
                                                                                                    "default":  "",
                                                                                                    "description":  "Optional absolute path to hSensors repository. Leave empty for auto-detection near hFramework."
                                                                                                },
                                                                 "husarionCore2.hModulesPath":  {
                                                                                                    "type":  "string",
                                                                                                    "default":  "",
                                                                                                    "description":  "Optional absolute path to hModules/modules repository. Leave empty for auto-detection near hFramework."
                                                                                                },
                                                                 "husarionCore2.openProjectInNewWindow":  {
                                                                                                              "type":  "boolean",
                                                                                                              "default":  false,
                                                                                                              "description":  "If true, opening a newly created project uses a new VS Code window."
                                                                                                          },
                                                                 "husarionCore2.checkUpdatesOnStartup":  {
                                                                                                             "type":  "boolean",
                                                                                                             "default":  true,
                                                                                                             "description":  "If true, checks GitHub releases on startup and offers guided update installation."
                                                                                                         },
                                                                 "husarionCore2.updateRepository":  {
                                                                                                        "type":  "string",
                                                                                                        "default":  "kotym/HusarionCore2Tools",
                                                                                                        "description":  "GitHub repository in owner/name format used for release update checks."
                                                                                                    }
                                                             }
                                          }
                    },
    "scripts":  {
                    "lint":  "echo \"No lint configured\""
                }
}